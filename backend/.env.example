# 通用 API 配置
ANTHROPIC_API_KEY=your_api_key_here
# 火山引擎 Ark 复用 ANTHROPIC_AUTH_TOKEN 或 ANTHROPIC_API_KEY
ANTHROPIC_AUTH_TOKEN=your_ark_token_here
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_KEY=your_api_key_here
CUSTOM_REPORT_URL=http://localhost:3000

# RAG 数据库配置
RAG_DB_HOST=localhost
RAG_DB_PORT=5432
RAG_DB_USER=postgres
RAG_DB_PASSWORD=
RAG_DB_NAME=postgres

# Embedding 配置
# EMBEDDING_PROVIDER 可选值: openai, ark
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# 火山引擎 Ark Embedding 配置
# 可选模型: doubao-embedding-v1, doubao-embedding-query-v1, doubao-embedding-document-v1, bge-large-zh, bge-base-zh
ARK_EMBEDDING_MODEL=doubao-embedding-v1

# Reranker 配置
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_TOP_N=5

# 检索配置
RETRIEVE_TOP_K=20

# 分片配置
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# 文档目录
RAG_DOCS_DIR=../docs/rag
